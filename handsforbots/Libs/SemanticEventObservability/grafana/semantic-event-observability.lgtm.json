          "editorMode": "code",
          "expr": "{service_name=\"semantic-event-observability\"} |= \"semantic_event\" | logfmt | line_format \"{{.event_data_name}} queue={{.event_data_queueDepth}} backend={{.event_data_callingBackend}}\"",
          "queryType": "range",
          "refId": "A"
        }
