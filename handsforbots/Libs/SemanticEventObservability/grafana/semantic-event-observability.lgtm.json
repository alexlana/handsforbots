      "options": {
        "cellHeight": "md",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "startTime" }]
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": "semantic-event-observability",
              "valueType": "string"
            },
            {
              "id": "turn-name",
              "operator": "=~",
              "scope": "span",
              "tag": "name",
              "value": "turn:.*",
              "valueType": "string"
            }
          ],
          "limit": 30,
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent turns",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "nested": true },
            "renameByName": {
              "traceDuration": "Total ms",
              "traceName": "Turn",
              "traceService": "Service"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": {
